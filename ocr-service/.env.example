# OCR Service — Variables d'environnement
# Copier en .env et remplir les valeurs

PORT=8000
ENVIRONMENT=development

# === BASE DE DONNÉES ===
# Local: postgresql://postgres:postgres@localhost:5432/suivi_production
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/suivi_production

# === CORS ===
FRONTEND_URL=http://localhost:3000

# === IA VISUELLE (NVIDIA NIM — gratuit) ===
# Obtenir une clé gratuite sur https://build.nvidia.com (bouton "Get API Key").
# Si vide → le service utilise uniquement le pipeline OCR local.
NVIDIA_API_KEY=
VISION_MODEL=meta/llama-3.2-90b-vision-instruct
VISION_ENABLED=true
