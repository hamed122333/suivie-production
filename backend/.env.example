# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=suivi_production
DB_USER=postgres
# CRITICAL: Change this in production!
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_IN_PRODUCTION

# JWT Configuration
# CRITICAL: Must be at least 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# CORS Configuration (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:3000
